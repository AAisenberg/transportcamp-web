# Mailchimp embedded signup form action URL (Audience → Signup forms → Embedded forms)
# Example: https://transportcamp.us21.list-manage.com/subscribe/post?u=XXXXXXXX&id=YYYYYYYY
NEXT_PUBLIC_MAILCHIMP_FORM_ACTION=

# Social profiles (optional — icons appear in footer and /contact/ when set)
NEXT_PUBLIC_X_URL=https://x.com/your-handle
NEXT_PUBLIC_LINKEDIN_URL=
# Leave blank until TransportCamp has an Instagram account
NEXT_PUBLIC_INSTAGRAM_URL=
